modules = ["nodejs-20", "nodejs-24", "postgresql-16", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "format"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Reviewer Pass Health Check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-whats-new"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "format"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run format"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Reviewer Pass Health Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "while true; do pnpm --filter @workspace/scripts run check-reviewer-pass; sleep 3600; done"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "check-whats-new"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check-whats-new"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 21176
externalPort = 3000

[[ports]]
localPort = 24483
externalPort = 3001

[[ports]]
localPort = 24484
externalPort = 3003

[[ports]]
localPort = 25837
externalPort = 4200

[userenv]

[userenv.shared]
REVENUECAT_TEST_API_KEY = "test_bFuwhHsDLTFRKigADFvnivhibip"
REVENUECAT_IOS_API_KEY = "appl_WDMeqvebStKVTwVninvrkxfFxat"
REVENUECAT_ANDROID_API_KEY = "goog_lYPbhsrnnJykPrxWtpBaZBzociP"
REVENUECAT_PROJECT_ID = "proj9120626a"
